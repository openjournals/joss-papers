  <ref id="ref-sakalukSamenessDifferencePsychological2021a">
    <element-citation publication-type="article-journal">
      <person-group person-group-type="author">
        <name><surname>Sakaluk</surname><given-names>John K.</given-names></name>
        <name><surname>Quinn-Nilas</surname><given-names>Christopher</given-names></name>
