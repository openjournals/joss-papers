      <article-title>Simulations of ellipsoidal primordial black hole formation</article-title>
      <source>Phys. Rev. D</source>
      <year iso-8601-date="2025">2025</year>
      <volume>112</volume>
      <issue>8</issue>
      <uri>https://arxiv.org/abs/2410.03452</uri>
