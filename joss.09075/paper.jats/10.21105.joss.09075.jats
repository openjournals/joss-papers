        </tr>
        <tr>
          <td align="left"><bold>Steady-state guards &amp; HR-coverage
          checks</bold></td>
          <td align="center">Yes</td>
          <td align="center">No</td>
          <td align="center">No</td>
          <td align="center">No</td>
          <td align="center">No</td>
