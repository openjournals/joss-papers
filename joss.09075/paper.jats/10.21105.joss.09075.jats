          <td align="left"><bold>API-limited (OAuth, scope,
          rate-limits)</bold></td>
          <td align="center">No</td>
          <td align="center">Yes</td>
          <td align="center">No</td>
          <td align="center">No</td>
          <td align="center">No</td>
          <td align="center">No</td>
        </tr>
        <tr>
          <td align="left"><bold>End-to-end pipeline
          (Import→QC→Models→Plot)</bold></td>
          <td align="center">Yes</td>
          <td align="center">No</td>
